    <title>文件生成Data URL</title>
    <url>/2023/08/17/%E6%96%87%E4%BB%B6%E7%94%9F%E6%88%90Data-URL/</url>
    <content><![CDATA[<script>
    document.write("<!DOCTYPE html>");
    document.write("<html xmlns=\"http:\/\/www.w3.org\/1999\/xhtml\">");
    document.write("<head>");
    document.write("  <meta http-equiv=\"Content-Type\" content=\"text\/html; charset=utf-8\" \/>");
    document.write("  <title>文件生成Data Url<\/title>");
    document.write("  <meta name=\"keywords\" content=\"Data Url,HTML5,FileReader\" \/>");
    document.write("  <meta name=\"description\" content=\"生成Data Url\" \/>");
    document.write("  <script type=\"text\/javascript\">");
    document.write("    function buildDataUrl(e) {");
    document.write("      var t,");
    document.write("        a = e.files[0];");
    document.write("      window.FileReader &&");
    document.write("        (((t = new FileReader()).onloadend = function (e) {");
    document.write("          (document.getElementById(\"txtBase64\").value = e.target.result),");
    document.write("            (document.getElementById(\"imgView\").src = e.target.result);");
    document.write("        }),");
    document.write("        t.readAsDataURL(a));");
    document.write("    }");
    document.write("  <\/script>");
    document.write("<\/head>");
    document.write("<body>");
    document.write("  <strong>文件转 Data URL <\/strong><hr\/>");
    document.write("  <div>");
    document.write("    <input");
    document.write("      type=\"file\"");
    document.write("      value=\"\"");
    document.write("      onchange=\"buildDataUrl(this)\"");
    document.write("      style=\"border: 1px solid grey; width: 300px\"");
    document.write("    \/><br \/><textarea id=\"txtBase64\" style=\"width: 50%; height: 300px\"><\/textarea>");
    document.write("    <img id=\"imgView\" src=\"\" style=\"height: 300px\" alt=\"没有可预览的图片\" \/>");
    document.write("  <\/div><br\/>");
    document.write("<\/body>");
    document.write("<\/html>");
    document.write("");
</script>
<figure class="highlight plaintext"><table><tr><td class="code"><pre><span class="line">使用方法：在上方选择文件，过段时间后data URL就会显示在大输入框中。</span><br><span class="line"></span><br><span class="line">白色图片可能不会显示预览，长按顶部栏换成黑色模式即可。</span><br></pre></td></tr></table></figure>
<p><strong>注：本工具不会收集您的任何数据</strong></p>
